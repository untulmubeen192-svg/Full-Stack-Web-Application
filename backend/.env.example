# ─────────────────────────────────────────────
#  Glow Untul Mubeen Beauty — Environment Variables
# ─────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# MongoDB Connection String
MONGO_URI=mongodb://127.0.0.1:27017/glow_beauty

# JWT Secrets (use long random strings in production)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Admin Credentials (for first-time seed)
ADMIN_EMAIL=admin@glowreeba.com
ADMIN_PASSWORD=Admin@123

# Email (Nodemailer — use Gmail App Password or SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# Frontend URL (for CORS & reset-password links)
FRONTEND_URL=http://127.0.0.1:5500

# WhatsApp Business Number (international format, no + or spaces)
WHATSAPP_NUMBER=923183826803
